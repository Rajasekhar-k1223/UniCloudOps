DATABASE_URL=mysql+pymysql://appuser:replace-with-strong-password@localhost:43306/unicloudops
MONGO_URL=mongodb://admin:replace-with-strong-password@localhost:37017/unicloudops?authSource=admin
REDIS_URL=redis://:replace-with-strong-password@localhost:16379/0
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENVIRONMENT=development
AUTO_SEED_DATA=false
AUTO_SEED_ADMIN=false
DEFAULT_ADMIN_EMAIL=admin@unicloudops.local
DEFAULT_ADMIN_PASSWORD=replace-before-enabling-admin-seed
DOCKER_HOST=unix:///var/run/docker.sock
